<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Credit Card Fraud Detection — AI Dashboard with prediction, visualization, and analytics">
    <title>Fraud Detection | AI Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛡️</text></svg>">
    <!-- Chart.js for training/evaluation charts -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
</head>
<body>

<!-- Mobile Hamburger Button -->
<button id="hamburger" class="hamburger" aria-label="Toggle menu">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
</button>

<!-- App Layout: Sidebar + Main Content -->
<div class="app-layout">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar__brand">
            <span class="sidebar__icon">🛡️</span>
            <span class="sidebar__label">Fraud Detection</span>
        </div>
        
        <button class="sidebar__toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 18l-6-6 6-6"/>
            </svg>
        </button>

        <nav class="sidebar__nav" role="tablist">
            <button class="sidebar__item active" data-tab="eda" role="tab" aria-selected="true">
                <span class="sidebar__item-icon">📊</span>
                <span class="sidebar__item-label">EDA Analysis</span>
            </button>
            <button class="sidebar__item" data-tab="architecture" role="tab">
                <span class="sidebar__item-icon">🧠</span>
                <span class="sidebar__item-label">Architecture</span>
            </button>
            <button class="sidebar__item" data-tab="training" role="tab">
                <span class="sidebar__item-icon">📈</span>
                <span class="sidebar__item-label">Training</span>
            </button>
            <button class="sidebar__item" data-tab="tuning" role="tab">
                <span class="sidebar__item-icon">⚙️</span>
                <span class="sidebar__item-label">Tuning</span>
            </button>
            <button class="sidebar__item" data-tab="evaluation" role="tab">
                <span class="sidebar__item-icon">📐</span>
                <span class="sidebar__item-label">Evaluation</span>
            </button>
            <button class="sidebar__item" data-tab="predict" role="tab">
                <span class="sidebar__item-icon">🔍</span>
                <span class="sidebar__item-label">Predict</span>
            </button>
        </nav>
        
        <!-- Theme Toggle (inside sidebar, above collapse button) -->
        <button id="theme-toggle" class="theme-toggle sidebar-theme-toggle" aria-label="Toggle dark mode">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"></circle>
                <line x1="12" y1="1" x2="12" y2="3"></line>
                <line x1="12" y1="21" x2="12" y2="23"></line>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                <line x1="1" y1="12" x2="3" y2="12"></line>
                <line x1="21" y1="12" x2="23" y2="12"></line>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
        </button>
    </aside>

<!-- Main Content -->
    <main class="main-content">

        <!-- Theme Toggle (bottom-right corner) -->
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"></circle>
                <line x1="12" y1="1" x2="12" y2="3"></line>
                <line x1="12" y1="21" x2="12" y2="23"></line>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                <line x1="1" y1="12" x2="3" y2="12"></line>
                <line x1="21" y1="12" x2="23" y2="12"></line>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
        </button>

        <div class="app-shell">

            <!-- Header (inside app-shell for EDA) -->
            <header class="header">
        <div class="header__brand">
            <div class="header__icon">🛡️</div>
            <h1>Credit Card Fraud Detection</h1>
        </div>
        <p class="header__sub">Neural Network Dashboard — Model Analytics & Real-Time Prediction</p>
</header>

    <!-- Main Content Area -->
    <div class="main-area">

        <!-- TAB 1: PREDICT -->
    <div class="tab-panel" id="panel-predict" role="tabpanel">

        <div class="card">
            <div class="card__header">
                <span class="card__header-icon">📝</span>
                <div>
                    <div class="card__title">Transaction Details</div>
                    <div class="card__subtitle">Enter transaction data for real-time fraud analysis</div>
                </div>
            </div>

            <form id="predict-form" class="form-grid" autocomplete="off">
                <div class="form-group">
                    <label for="amt">Transaction Amount ($)</label>
                    <input type="number" id="amt" name="amt" step="0.01" min="0" placeholder="e.g. 125.50" required>
                </div>
                <div class="form-group">
                    <label for="category">Category</label>
                    <select id="category" name="category" required>
                        <option value="" disabled selected>Select category</option>
                        {% for cat in categories %}
                        <option value="{{ cat }}">{{ cat | replace('_', ' ') | title }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group">
                    <label for="trans_date_trans_time">Transaction Date & Time</label>
                    <input type="datetime-local" id="trans_date_trans_time" name="trans_date_trans_time" required>
                </div>
                <div class="form-group">
                    <label for="city_pop">City Population</label>
                    <input type="number" id="city_pop" name="city_pop" min="0" placeholder="e.g. 50000" required>
                </div>

                <div class="section-label">Cardholder Information</div>
                <div class="form-group">
                    <label for="gender">Gender</label>
                    <select id="gender" name="gender" required>
                        <option value="" disabled selected>Select gender</option>
                        {% for g in genders %}
                        <option value="{{ g }}">{{ 'Female' if g == 'F' else 'Male' }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group">
                    <label for="state">State</label>
                    <select id="state" name="state" required>
                        <option value="" disabled selected>Select state</option>
                        {% for s in states %}
                        <option value="{{ s }}">{{ s }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group">
                    <label for="dob">Date of Birth</label>
                    <input type="date" id="dob" name="dob" required>
                </div>
                <div class="form-group">
                    <label>&nbsp;</label>
                    <input type="text" style="visibility:hidden" tabindex="-1" aria-hidden="true">
                </div>

                <div class="section-label">Location Information</div>
                <div class="form-group full-width">
                    <label for="distance_km">Distance from Home Address (km)</label>
                    <input type="number" id="distance_km" name="distance_km" step="any" min="0" placeholder="e.g. 5.5" required>
                </div>

                <button type="submit" class="btn-predict" id="btn-submit">Analyze Transaction</button>
            </form>
            <div class="error-msg" id="error-msg"></div>
        </div>

        <!-- Result Card -->
        <div class="card" id="result-card">
            <div class="card__header">
                <span class="card__header-icon">📊</span>
                <div class="card__title">Analysis Result</div>
            </div>
            <div class="result-content">
                <div class="result-prediction" id="result-prediction"></div>
                <div class="result-probability" id="result-probability"></div>
                <div class="prob-bar-container">
                    <div class="prob-bar-bg"><div class="prob-bar-fill" id="prob-bar-fill"></div></div>
                    <div class="prob-bar-labels"><span>0%</span><span>50%</span><span>100%</span></div>
                </div>
                <div style="margin-top:18px"><span class="risk-badge" id="risk-badge"></span></div>
                <div class="threshold-note" id="threshold-note"></div>
                <div class="distance-note" id="distance-note"></div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════
         TAB 2: ARCHITECTURE
         ═══════════════════════════════════════════════════ -->
    <div class="tab-panel" id="panel-architecture" role="tabpanel">

        <!-- Model Summary Stats -->
        <div class="stats-row" id="arch-stats">
            <div class="stat-card"><div class="stat-card__value blue">—</div><div class="stat-card__label">Total Params</div></div>
            <div class="stat-card"><div class="stat-card__value green">—</div><div class="stat-card__label">Trainable</div></div>
            <div class="stat-card"><div class="stat-card__value orange">—</div><div class="stat-card__label">Non-Trainable</div></div>
            <div class="stat-card"><div class="stat-card__value cyan">15</div><div class="stat-card__label">Input Features</div></div>
        </div>

        <!-- Input Features -->
        <div class="card">
            <div class="card__header">
                <span class="card__header-icon">📐</span>
                <div>
                    <div class="card__title">Input Features (15)</div>
                    <div class="card__subtitle">Features used for fraud prediction</div>
                </div>
            </div>
            <div class="model-info-grid" id="feature-grid"></div>
        </div>

        <!-- Neural Network Diagram -->
        <div class="card">
            <div class="card__header">
                <span class="card__header-icon">🧠</span>
                <div>
                    <div class="card__title">Neural Network Architecture</div>
                    <div class="card__subtitle">MLP: 15 → 256 → 128 → 64 → 1 (Sigmoid)</div>
                </div>
            </div>
            <div class="nn-canvas-container">
                <canvas class="nn-canvas" id="nn-canvas"></canvas>
            </div>
        </div>

        <!-- Layer Details -->
        <div class="card">
            <div class="card__header">
                <span class="card__header-icon">📋</span>
                <div>
                    <div class="card__title">Layer Details</div>
                    <div class="card__subtitle">Hover over layers for more information</div>
                </div>
            </div>
            <div class="layer-grid" id="layer-grid">
                <div class="loading-overlay"><span class="spinner"></span> Loading architecture...</div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════
         TAB 3: TRAINING
         ═══════════════════════════════════════════════════ -->
    <div class="tab-panel" id="panel-training" role="tabpanel">

        <div class="stats-row" id="training-stats">
            <div class="stat-card"><div class="stat-card__value blue" id="ts-epochs">—</div><div class="stat-card__label">Epochs</div></div>
            <div class="stat-card"><div class="stat-card__value green" id="ts-best">—</div><div class="stat-card__label">Best Epoch</div></div>
            <div class="stat-card"><div class="stat-card__value cyan" id="ts-val-auc">—</div><div class="stat-card__label">Best Val AUC</div></div>
            <div class="stat-card"><div class="stat-card__value orange" id="ts-val-loss">—</div><div class="stat-card__label">Best Val Loss</div></div>
            <div class="stat-card"><div class="stat-card__value purple" id="ts-lr">—</div><div class="stat-card__label">Final LR</div></div>
        </div>

        <div class="chart-grid">
            <div class="chart-container">
                <div class="chart-container__title">Loss Curve</div>
                <div style="position: relative; height: 200px; width: 100%;">
                    <canvas id="chart-loss"></canvas>
                </div>
            </div>
            <div class="chart-container">
                <div class="chart-container__title">AUC Curve</div>
                <div style="position: relative; height: 200px; width: 100%;">
                    <canvas id="chart-auc"></canvas>
                </div>
            </div>
            <div class="chart-container">
                <div class="chart-container__title">Accuracy Curve</div>
                <div style="position: relative; height: 200px; width: 100%;">
                    <canvas id="chart-acc"></canvas>
                </div>
            </div>
            <div class="chart-container">
                <div class="chart-container__title">Training Summary</div>
                <div class="model-info-grid" id="training-summary" style="padding:8px 0">
                    <div class="loading-overlay"><span class="spinner"></span> Loading...</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════
         TAB 4: EVALUATION
         ═══════════════════════════════════════════════════ -->
    <div class="tab-panel" id="panel-evaluation" role="tabpanel">

        <div class="stats-row" id="eval-stats">
            <div class="stat-card"><div class="stat-card__value blue" id="ev-roc">—</div><div class="stat-card__label">ROC-AUC</div></div>
            <div class="stat-card"><div class="stat-card__value green" id="ev-pr">—</div><div class="stat-card__label">PR-AUC</div></div>
            <div class="stat-card"><div class="stat-card__value cyan" id="ev-recall">—</div><div class="stat-card__label">Recall (Fraud)</div></div>
            <div class="stat-card"><div class="stat-card__value orange" id="ev-precision">—</div><div class="stat-card__label">Precision (Fraud)</div></div>
            <div class="stat-card"><div class="stat-card__value purple" id="ev-f1">—</div><div class="stat-card__label">F1 (Fraud)</div></div>
        </div>

        <div class="chart-grid">
            <!-- Confusion Matrix -->
            <div class="chart-container">
                <div class="chart-container__title">Confusion Matrix</div>
                <div class="cm-grid" id="confusion-matrix">
                    <div class="cm-label"></div>
                    <div class="cm-label">Pred Legit</div>
                    <div class="cm-label">Pred Fraud</div>
                    <div class="cm-label vertical">Actual Legit</div>
                    <div class="cm-cell cm-tn">
                        <div class="cm-cell__value" id="cm-tn">—</div>
                        <div class="cm-cell__label">True Neg</div>
                    </div>
                    <div class="cm-cell cm-fp">
                        <div class="cm-cell__value" id="cm-fp">—</div>
                        <div class="cm-cell__label">False Pos</div>
                    </div>
                    <div class="cm-label vertical">Actual Fraud</div>
                    <div class="cm-cell cm-fn">
                        <div class="cm-cell__value" id="cm-fn">—</div>
                        <div class="cm-cell__label">False Neg</div>
                    </div>
                    <div class="cm-cell cm-tp">
                        <div class="cm-cell__value" id="cm-tp">—</div>
                        <div class="cm-cell__label">True Pos</div>
                    </div>
                </div>
            </div>

            <div class="chart-container">
                <div class="chart-container__title">Classification Metrics</div>
                <div style="position: relative; height: 220px; width: 100%;">
                    <canvas id="chart-metrics"></canvas>
                </div>
            </div>

            <div class="chart-container">
                <div class="chart-container__title">ROC Curve (AUC = 0.9877)</div>
                <div style="position: relative; height: 220px; width: 100%;">
                    <canvas id="chart-roc"></canvas>
                </div>
            </div>

            <!-- Dataset Info -->
            <div class="chart-container">
                <div class="chart-container__title">Dataset Summary</div>
                <div class="model-info-grid" id="dataset-info" style="padding:8px 0"></div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════
         TAB 5: TUNING
         ═══════════════════════════════════════════════════ -->
    <div class="tab-panel" id="panel-tuning" role="tabpanel">

        <div class="stats-row" id="tuning-stats">
            <div class="stat-card"><div class="stat-card__value blue" id="tu-trials">—</div><div class="stat-card__label">Total Trials</div></div>
            <div class="stat-card"><div class="stat-card__value green" id="tu-best-score">—</div><div class="stat-card__label">Best Score</div></div>
            <div class="stat-card"><div class="stat-card__value cyan" id="tu-best-roc">—</div><div class="stat-card__label">Best ROC-AUC</div></div>
            <div class="stat-card"><div class="stat-card__value orange" id="tu-best-pr">—</div><div class="stat-card__label">Best PR-AUC</div></div>
        </div>

        <!-- Score Comparison Chart -->
        <div class="card">
            <div class="card__header">
                <span class="card__header-icon">📊</span>
                <div>
                    <div class="card__title">Trial Score Comparison</div>
                    <div class="card__subtitle">Composite score = mean(ROC-AUC, PR-AUC)</div>
                </div>
            </div>
            <div style="height:280px; padding:8px 0">
                <canvas id="chart-tuning"></canvas>
            </div>
        </div>

        <!-- Full Results Table -->
        <div class="card card--flush">
            <div style="padding:20px 24px 0">
                <div class="card__header" style="margin-bottom:12px">
                    <span class="card__header-icon">📋</span>
                    <div>
                        <div class="card__title">All Trial Results</div>
                        <div class="card__subtitle">Sorted by composite score (descending)</div>
                    </div>
                </div>
            </div>
            <div class="table-wrapper">
                <table class="data-table" id="tuning-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Architecture</th>
                            <th>Dropout</th>
                            <th>LR</th>
                            <th>Batch</th>
                            <th>Epochs</th>
                            <th>ROC-AUC</th>
                            <th>PR-AUC</th>
                            <th>Score</th>
                        </tr>
                    </thead>
                    <tbody id="tuning-tbody">
                        <tr><td colspan="9" style="text-align:center;color:var(--text-muted);padding:30px">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════
         TAB 6: EDA ANALYSIS
         ═══════════════════════════════════════════════════ -->
    <div class="tab-panel active" id="panel-eda" role="tabpanel">

        <!-- Section Header -->
        <div class="eda-header">
            <h2 class="eda-header__title">Exploratory Data Analysis — Credit Card Fraud</h2>
            <p class="eda-header__subtitle">13 visualizations revealing hidden patterns in the fraud detection dataset</p>
        </div>

        <!-- ─── GRAPH 1 — Class Imbalance (Full Width) ─── -->
        <div class="eda-card eda-full">
            <div class="eda-card__badge">Graph 1 of 13</div>
            <div class="eda-card__chart-title">The Needle in the Haystack: Genuine vs Fraudulent Transactions</div>
            <div style="position:relative; width:100%; height:320px;">
                <canvas id="eda-chart-1"></canvas>
            </div>
            <div class="eda-card__desc">
                <p class="eda-card__headline">Fraud is highly uncommon but incredibly damaging.</p>
                <p class="eda-card__insights"><strong>Insights:</strong> Out of ~555,000 transactions, only a tiny fraction were fraudulent.</p>
                <p class="eda-card__takeaway"><strong>Takeaway:</strong> This represents just 0.42% of the data. When building a Machine Learning model, we must use techniques like SMOTE (Synthetic Minority Oversampling) or adjust class weights — otherwise, the model will just guess "Not Fraud" every time and be 99.58% "accurate" while failing to catch any actual fraud.</p>
            </div>
        </div>

        <!-- ─── GRAPH 2 & 3 — Side by Side ─── -->
        <div class="eda-row">
            <!-- GRAPH 2 — Transaction Amounts -->
            <div class="eda-card">
                <div class="eda-card__badge">Graph 2 of 13</div>
                <div class="eda-card__chart-title">Do Fraudsters Steal Big or Small? (Transaction Amounts)</div>
                <div style="position:relative; width:100%; height:340px;">
                    <canvas id="eda-chart-2"></canvas>
                </div>
                <div class="eda-card__desc">
                    <p class="eda-card__headline">Fraudsters rarely make small purchases.</p>
                    <p class="eda-card__insights"><strong>Insights:</strong> Genuine transactions peak heavily at low values (under $50) for everyday items like coffee and groceries.</p>
                    <p class="eda-card__takeaway"><strong>Takeaway:</strong> Fraudulent transactions have a much flatter, wider distribution, frequently spiking in the $250–$1,000 range. Fraudsters want to maximize their payout before the card is blocked.</p>
                </div>
            </div>

            <!-- GRAPH 3 — Time of Day -->
            <div class="eda-card">
                <div class="eda-card__badge">Graph 3 of 13</div>
                <div class="eda-card__chart-title">When Does Fraud Happen? (Time of Day)</div>
                <div style="position:relative; width:100%; height:340px;">
                    <canvas id="eda-chart-3"></canvas>
                </div>
                <div class="eda-card__desc">
                    <p class="eda-card__headline">Fraud primarily strikes while the victim is sleeping.</p>
                    <p class="eda-card__insights"><strong>Insights:</strong> Normal spending peaks during the day (10 AM to 6 PM) and plummets late at night.</p>
                    <p class="eda-card__takeaway"><strong>Takeaway:</strong> Fraud spikes violently between 10 PM and 3 AM. Fraudsters operate at night when victims are asleep and unlikely to notice banking notifications on their phones.</p>
                </div>
            </div>
        </div>

        <!-- ─── GRAPH 4 — Categories (Full Width) ─── -->
        <div class="eda-card eda-full">
            <div class="eda-card__badge">Graph 4 of 13</div>
            <div class="eda-card__chart-title">Which Categories Are Most Vulnerable to Fraud?</div>
            <div style="position:relative; width:100%; height:380px;">
                <canvas id="eda-chart-4"></canvas>
            </div>
            <div class="eda-card__desc">
                <p class="eda-card__headline">Online shopping and groceries are prime targets.</p>
                <p class="eda-card__insights"><strong>Insights:</strong> The chart shows the proportion of fraud within specific merchant categories. shopping_net (Online Shopping) and grocery_pos (Grocery Point of Sale) see the highest rates of fraud.</p>
                <p class="eda-card__takeaway"><strong>Takeaway:</strong> Online shopping is highly vulnerable because it is a "Card-Not-Present" (CNP) transaction — the fraudster only needs the card numbers, not the physical card itself.</p>
            </div>
        </div>

        <!-- ─── GRAPH 5 & 6 — Side by Side ─── -->
        <div class="eda-row">
            <!-- GRAPH 5 — Age Distribution -->
            <div class="eda-card">
                <div class="eda-card__badge">Graph 5 of 13</div>
                <div class="eda-card__chart-title">Who Are the Victims? (Age Distribution)</div>
                <div style="position:relative; width:100%; height:340px;">
                    <canvas id="eda-chart-5"></canvas>
                </div>
                <div class="eda-card__desc">
                    <p class="eda-card__headline">Does age play a factor in credit card fraud?</p>
                    <p class="eda-card__insights"><strong>Insights:</strong> The age distributions for both normal and fraudulent transactions are surprisingly similar, generally peaking between 30 and 50 years old.</p>
                    <p class="eda-card__takeaway"><strong>Takeaway:</strong> Unlike internet scams (which heavily target the elderly), credit card fraud is an automated numbers game. Hackers buy bulk card details on the dark web; they don't care about the age of the victim, only that the card has a balance.</p>
                </div>
            </div>

            <!-- GRAPH 6 — Distance to Merchant -->
            <div class="eda-card">
                <div class="eda-card__badge">Graph 6 of 13</div>
                <div class="eda-card__chart-title">How Far is the Merchant from the Victim?</div>
                <div style="position:relative; width:100%; height:340px;">
                    <canvas id="eda-chart-6"></canvas>
                </div>
                <div class="eda-card__desc">
                    <p class="eda-card__headline">Physical distance from the merchant is a weak indicator of fraud.</p>
                    <p class="eda-card__insights"><strong>Insights:</strong> The distance (in kilometers) between the victim's home address and the merchant's location is very similar for both genuine and fraudulent transactions. The distributions overlap heavily.</p>
                    <p class="eda-card__takeaway"><strong>Takeaway:</strong> Because a large portion of modern fraud occurs online (shopping_net), the physical location of the merchant matters less than it did a decade ago. Distance alone is not a strong fraud signal.</p>
                </div>
            </div>
        </div>

        <!-- ─── GRAPH 7 & 8 — Side by Side ─── -->
        <div class="eda-row">
            <!-- GRAPH 7 — Day of Week -->
            <div class="eda-card">
                <div class="eda-card__badge">Graph 7 of 13</div>
                <div class="eda-card__chart-title">Are Weekends More Dangerous? (Fraud Rate by Day)</div>
                <div style="position:relative; width:100%; height:320px;">
                    <canvas id="eda-chart-7"></canvas>
                </div>
                <div class="eda-card__desc">
                    <p class="eda-card__headline">Fraudsters don't take the weekend off.</p>
                    <p class="eda-card__insights"><strong>Insights:</strong> By plotting the rate of fraud across all 7 days of the week, we can observe cyclical behaviors in fraudulent activity.</p>
                    <p class="eda-card__takeaway"><strong>Takeaway:</strong> Fraud rates often spike on weekends (Saturday/Sunday). Fraudsters may time their attacks for periods when bank customer service desks are closed or understaffed, making it harder for victims to freeze their cards in time.</p>
                </div>
            </div>

            <!-- GRAPH 8 — Gender Split -->
            <div class="eda-card">
                <div class="eda-card__badge">Graph 8 of 13</div>
                <div class="eda-card__chart-title">Average Amount Stolen: Men vs. Women</div>
                <div style="position:relative; width:100%; height:340px;">
                    <canvas id="eda-chart-8"></canvas>
                </div>
                <div class="eda-card__desc">
                    <p class="eda-card__headline">Do fraudsters steal more from men or women?</p>
                    <p class="eda-card__insights"><strong>Insights:</strong> While genuine transaction averages are almost identical for men and women (around $65–$68), the fraudulent amounts tell a different story — with slightly higher average stolen amounts from female cardholders.</p>
                    <p class="eda-card__takeaway"><strong>Takeaway:</strong> This doesn't mean fraudsters are targeting a specific gender on purpose. It usually reflects the credit limits granted to those demographics in the dataset, or the types of merchants they shop at.</p>
                </div>
            </div>
        </div>

        <!-- ─── GRAPH 9 — Top States (Full Width) ─── -->
        <div class="eda-card eda-full">
            <div class="eda-card__badge">Graph 9 of 13</div>
            <div class="eda-card__chart-title">Top 10 US States with the Highest Fraud Rates</div>
            <div style="position:relative; width:100%; height:340px;">
                <canvas id="eda-chart-9"></canvas>
            </div>
            <div class="eda-card__desc">
                <p class="eda-card__headline">Fraud is not distributed equally across the map.</p>
                <p class="eda-card__insights"><strong>Insights:</strong> After filtering out states with tiny sample sizes (to avoid skewed percentages), we isolated the Top 10 states with the highest percentage of compromised transactions.</p>
                <p class="eda-card__takeaway"><strong>Takeaway:</strong> While the internet is borderless, victims in specific states exhibit higher vulnerability. This could be tied to regional wealth, the prevalence of certain targeted banks in those areas, or targeted phishing campaigns hitting specific regional zip codes.</p>
            </div>
        </div>

        <!-- ─── GRAPH 10 & 11 — Side by Side ─── -->
        <div class="eda-row">
            <!-- GRAPH 10 — Urban vs Rural -->
            <div class="eda-card">
                <div class="eda-card__badge">Graph 10 of 13</div>
                <div class="eda-card__chart-title">Where Do Victims Live? (Urban vs Rural)</div>
                <div style="position:relative; width:100%; height:320px;">
                    <canvas id="eda-chart-10"></canvas>
                </div>
                <div class="eda-card__desc">
                    <p class="eda-card__headline">Big cities vs. small towns — who is more vulnerable?</p>
                    <p class="eda-card__insights"><strong>Insights:</strong> Victims' city populations were bucketed into Rural (&lt;50k), Suburban (50k–250k), and Urban (&gt;250k) categories to compare fraud rates.</p>
                    <p class="eda-card__takeaway"><strong>Takeaway:</strong> Smaller towns sometimes show higher rates of fraud because a single localized data breach (like a local gas station skimmer) heavily skews the math for a small population. Urban areas have massive transaction volumes that dilute individual breach impacts.</p>
                </div>
            </div>

            <!-- GRAPH 11 — Stolen Funds by Category -->
            <div class="eda-card">
                <div class="eda-card__badge">Graph 11 of 13</div>
                <div class="eda-card__chart-title">Distribution of Stolen Funds by Category (Fraud Only)</div>
                <div style="position:relative; width:100%; height:400px;">
                    <canvas id="eda-chart-11"></canvas>
                </div>
                <div class="eda-card__desc">
                    <p class="eda-card__headline">Not all fraud is high-ticket.</p>
                    <p class="eda-card__insights"><strong>Insights:</strong> Earlier we saw where fraud happens (by category). Now we see how much is stolen there. Categories like shopping_pos (Physical Retail) and misc_net have large spreads with highly varying amounts.</p>
                    <p class="eda-card__takeaway"><strong>Takeaway:</strong> Fraudsters use gas stations (gas_transport) to "test" if a stolen card is still active with a small ~$10 charge — before making a massive $500–$800 purchase at a retail store. This is called a test transaction pattern and is a known fraud red flag.</p>
                </div>
            </div>
        </div>

        <!-- ─── GRAPH 12 — Most Exploited Merchants (Full Width) ─── -->
        <div class="eda-card eda-full">
            <div class="eda-card__badge">Graph 12 of 13</div>
            <div class="eda-card__chart-title">The Top 10 Most Exploited Merchants</div>
            <div style="position:relative; width:100%; height:380px;">
                <canvas id="eda-chart-12"></canvas>
            </div>
            <div class="eda-card__desc">
                <p class="eda-card__headline">The specific targets of fraudsters.</p>
                <p class="eda-card__insights"><strong>Insights:</strong> This chart shows the literal names of the merchants that processed the most fraudulent transactions. Note that the dataset prefixes merchant names with "fraud_" as part of its synthetic labeling convention.</p>
                <p class="eda-card__takeaway"><strong>Takeaway:</strong> Many of these merchants are general retail, online services, or fake shell companies set up by the hackers themselves to funnel money. If we were building a live fraud-detection engine, transactions at these specific vendors would immediately trigger a high-risk alert.</p>
            </div>
        </div>

        <!-- ─── GRAPH 13 — Correlation Heatmap (Full Width) ─── -->
        <div class="eda-card eda-full">
            <div class="eda-card__badge">Graph 13 of 13</div>
            <div class="eda-card__chart-title">Correlation Heatmap: Relationship Between Features</div>
            <div class="eda-heatmap-container" id="eda-heatmap"></div>
            <div class="eda-card__desc">
                <p class="eda-card__headline">Proving the need for a Deep Learning approach.</p>
                <p class="eda-card__insights"><strong>Insights:</strong> The heatmap shows that transaction amount (amt) has only a weak linear relationship (0.18) with fraud, while every other feature is near zero. This confirms there are no "obvious" linear paths to identify fraudsters in the raw data.</p>
                <p class="eda-card__takeaway"><strong>Takeaway:</strong> This lack of linear correlation is exactly why we use a Neural Network. While simple models fail when variables don't correlate directly, the hidden layers of a neural network can synthesize these weak, independent signals (like amt + hour + category together) into powerful non-linear fraud detectors. A logistic regression or linear model would fail here; a deep neural network succeeds.</p>
            </div>
        </div>

    </div>

    <!-- Footer -->
    <footer class="footer">
        Fraud Detection Dashboard &middot; Powered by <span>TensorFlow</span> &amp; <span>Flask</span> &middot; MLP [256, 128, 64]
    </footer>

</div><!-- /.main-area -->
</div><!-- /.app-shell -->
</main><!-- /.main-content -->
</div><!-- /.app-layout -->
<script>
(function() {
    // ─── Theme Management ────────────────────────────────
    const html = document.documentElement;
    const themeToggle = document.getElementById('theme-toggle');

    // Restore saved theme
    const savedTheme = localStorage.getItem('fd-theme') || 'light';
    html.setAttribute('data-theme', savedTheme);

    themeToggle.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'light' ? 'dark' : 'light';
        html.setAttribute('data-theme', next);
        localStorage.setItem('fd-theme', next);
        // Re-apply chart colors if charts exist
        updateChartTheme();
    });

    function isDark() {
        return html.getAttribute('data-theme') === 'dark';
    }

    // ─── Theme-Aware Color Helpers ───────────────────────
    function C(lightVal, darkVal) {
        return isDark() ? darkVal : lightVal;
    }

    function getChartColors() {
        return {
            grid:      C('rgba(0,0,0,0.06)', 'rgba(255,255,255,0.06)'),
            tick:      C('#737373', '#A1A1AA'),
            labelStrong: C('#171717', '#EDEDED'),
            blue:      C('#5B7BA4', '#7B9BC4'),
            terra:     C('#C07A5C', '#D49A7C'),
            green:     C('#6B8F71', '#8BAF91'),
            red:       C('#B85450', '#D87470'),
            amber:     C('#C49B3C', '#D4BB5C'),
            teal:      C('#5E8C8C', '#7EACAC'),
            mauve:     C('#8B7BA4', '#AB9BC4'),
            slate:     C('#7C8B9A', '#9CAABB'),
            bg:        C('#FFFFFF', '#0A0A0A'),
            bgSecondary: C('#F5F5F5', '#141414'),
        };
    }

    // ─── Chart.js Global Defaults ────────────────────────
    function applyChartDefaults() {
        const c = getChartColors();
        Chart.defaults.color = c.tick;
        Chart.defaults.borderColor = c.grid;
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.font.size = 11;
        Chart.defaults.plugins.legend.labels.usePointStyle = true;
        Chart.defaults.plugins.legend.labels.pointStyleWidth = 8;
    }
    applyChartDefaults();

    // Store chart instances for theme updates
    const chartInstances = {};

    function updateChartTheme() {
        applyChartDefaults();
        // Destroy and reload if tabs were already loaded
        Object.keys(chartInstances).forEach(key => {
            if (chartInstances[key]) {
                chartInstances[key].destroy();
                chartInstances[key] = null;
            }
        });
        // Re-render active charts
        Object.keys(loaded).forEach(tab => {
            loaded[tab] = false;
        });
        const activeTab = document.querySelector('.sidebar__item.active')?.dataset.tab;
        if (activeTab) {
            loaded[activeTab] = true;
            if (activeTab === 'architecture') loadArchitecture();
            if (activeTab === 'training')     loadTraining();
            if (activeTab === 'evaluation')   loadEvaluation();
            if (activeTab === 'tuning')       loadTuning();
            if (activeTab === 'eda')          { edaChartsInitialized = false; initEdaCharts(); }
        }
    }

    // ─── Tab Switching ───────────────────────────────────
    const tabBtns = document.querySelectorAll('.sidebar__item');
    const tabPanels = document.querySelectorAll('.tab-panel');
    const loaded = {};
    let edaChartsInitialized = false;

    // Auto-load EDA on first boot if it's the default active tab
    if (document.getElementById('panel-eda').classList.contains('active')) {
        loaded['eda'] = true;
        initEdaCharts();
    }

    tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const tab = btn.dataset.tab;
            tabBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
            tabPanels.forEach(p => p.classList.remove('active'));
            btn.classList.add('active');
            btn.setAttribute('aria-selected','true');
            document.getElementById('panel-' + tab).classList.add('active');

            // Lazy-load data
            if (!loaded[tab]) {
                loaded[tab] = true;
                if (tab === 'architecture') loadArchitecture();
                if (tab === 'training')     loadTraining();
                if (tab === 'evaluation')   loadEvaluation();
                if (tab === 'tuning')       loadTuning();
                if (tab === 'eda')          initEdaCharts();
            }
        });
    });

    // ─── Sidebar Toggle ────────────────────────────────
    const sidebar = document.getElementById('sidebar');
    const sidebarToggle = document.getElementById('sidebar-toggle');
    if (sidebarToggle) {
        sidebarToggle.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
        });
    }

    // Mobile hamburger
    const hamburger = document.getElementById('hamburger');
    if (hamburger) {
        hamburger.addEventListener('click', () => {
            sidebar.classList.toggle('open');
        });
    }

    // ═══════════════════════════════════════════════════
    // PREDICT TAB
    // ═══════════════════════════════════════════════════
    const form = document.getElementById('predict-form');
    const btnSubmit = document.getElementById('btn-submit');
    const errorDiv = document.getElementById('error-msg');
    const resultCard = document.getElementById('result-card');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        hideError(); hideResult();

        const data = {};
        const fields = ['amt','category','gender','state','distance_km','city_pop','dob','trans_date_trans_time'];
        for (const f of fields) {
            const el = document.getElementById(f);
            if (!el || el.value === '') { showError('Please fill in all fields.'); return; }
            data[f] = el.value;
        }
        data.trans_date_trans_time = data.trans_date_trans_time.replace('T', ' ');

        setLoading(true);
        try {
            const res = await fetch('/predict', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) });
            const result = await res.json();
            if (!res.ok) throw new Error(result.error || 'Server error');
            showResult(result);
        } catch (err) {
            showError(err.message || 'Something went wrong.');
        } finally { setLoading(false); }
    });

    function setLoading(on) {
        btnSubmit.disabled = on;
        btnSubmit.innerHTML = on ? '<span class="spinner"></span> Analyzing...' : 'Analyze Transaction';
    }

    function showResult(r) {
        const predEl = document.getElementById('result-prediction');
        predEl.textContent = r.prediction === 'FRAUD' ? '⚠️ FRAUD DETECTED' : '✅ LEGITIMATE';
        predEl.className = 'result-prediction ' + (r.prediction === 'FRAUD' ? 'fraud' : 'legit');

        document.getElementById('result-probability').innerHTML = r.probability.toFixed(1) + '<span class="pct">%</span>';

        const bar = document.getElementById('prob-bar-fill');
        bar.className = 'prob-bar-fill ' + r.risk.toLowerCase();
        bar.style.width = '0%';
        requestAnimationFrame(() => requestAnimationFrame(() => bar.style.width = r.probability + '%'));

        const badge = document.getElementById('risk-badge');
        const icons = {high:'🔴', medium:'🟠', low:'🟢'};
        badge.className = 'risk-badge ' + r.risk.toLowerCase();
        badge.textContent = icons[r.risk.toLowerCase()] + ' ' + r.risk + ' RISK';

        document.getElementById('threshold-note').textContent = 'Decision threshold: ' + r.threshold + '%';
        document.getElementById('distance-note').textContent = 'Distance to merchant: ' + (r.distance_km || 0) + ' km';

        resultCard.classList.remove('show');
        void resultCard.offsetWidth;
        resultCard.classList.add('show');
        resultCard.scrollIntoView({behavior:'smooth', block:'center'});
    }

    function hideResult() { resultCard.classList.remove('show'); }
    function showError(msg) { errorDiv.textContent = msg; errorDiv.classList.add('show'); }
    function hideError() { errorDiv.classList.remove('show'); }

    // ═══════════════════════════════════════════════════
    // ARCHITECTURE TAB
    // ═══════════════════════════════════════════════════
    async function loadArchitecture() {
        try {
            const res = await fetch('/api/architecture');
            const data = await res.json();

            // Update stats
            const stats = document.querySelectorAll('#arch-stats .stat-card__value');
            stats[0].textContent = data.total_params.toLocaleString();
            stats[1].textContent = data.trainable_params.toLocaleString();
            stats[2].textContent = data.non_trainable_params.toLocaleString();

            // Draw Neural Network
            drawNeuralNetwork(data);

            // Layer cards
            const grid = document.getElementById('layer-grid');
            grid.innerHTML = '';
            data.layers.forEach(l => {
                const card = document.createElement('div');
                card.className = 'layer-card';
                let details = `<div class="layer-card__detail">Params: <span>${l.params.toLocaleString()}</span></div>`;
                details += `<div class="layer-card__detail">Shape: <span>${l.output_shape}</span></div>`;
                if (l.config.units) details += `<div class="layer-card__detail">Units: <span>${l.config.units}</span></div>`;
                if (l.config.activation) details += `<div class="layer-card__detail">Activation: <span>${l.config.activation}</span></div>`;
                if (l.config.rate !== undefined) details += `<div class="layer-card__detail">Rate: <span>${l.config.rate}</span></div>`;
                if (l.config.momentum) details += `<div class="layer-card__detail">Momentum: <span>${l.config.momentum}</span></div>`;
                card.innerHTML = `<div class="layer-card__type">${l.type}</div><div class="layer-card__name">${l.name}</div>${details}`;
                grid.appendChild(card);
            });

            // Feature list
            const fgrid = document.getElementById('feature-grid');
            fgrid.innerHTML = '';
            data.input_features.forEach((f, i) => {
                const item = document.createElement('div');
                item.className = 'model-info-item';
                item.innerHTML = `<div class="model-info-item__label">Feature ${i+1}</div><div class="model-info-item__value">${f}</div>`;
                fgrid.appendChild(item);
            });

        } catch (err) {
            document.getElementById('layer-grid').innerHTML = '<div style="padding:20px;color:var(--color-danger)">Error loading architecture</div>';
        }
    }

    function drawNeuralNetwork(data) {
        const canvas = document.getElementById('nn-canvas');
        const ctx = canvas.getContext('2d');
        const dpr = window.devicePixelRatio || 1;
        const c = getChartColors();

        canvas.width = canvas.offsetWidth * dpr;
        canvas.height = canvas.offsetHeight * dpr;
        ctx.scale(dpr, dpr);

        const W = canvas.offsetWidth;
        const H = canvas.offsetHeight;

        // Define layers to visualize
        const layers = [
            { label: 'Input',    neurons: 15, color: c.teal,  sub: '15 features' },
            { label: 'Dense+BN', neurons: 12, color: c.blue,  sub: '256 neurons', actual: 256 },
            { label: 'Dense+BN', neurons: 8,  color: c.mauve, sub: '128 neurons', actual: 128 },
            { label: 'Dense+BN', neurons: 5,  color: c.slate, sub: '64 neurons',  actual: 64 },
            { label: 'Output',   neurons: 1,  color: c.green, sub: 'Sigmoid' },
        ];

        const padding = { x: 60, y: 40 };
        const layerSpacing = (W - padding.x * 2) / (layers.length - 1);
        const maxNeurons = Math.max(...layers.map(l => l.neurons));

        // Calculate positions
        const positions = layers.map((layer, li) => {
            const x = padding.x + li * layerSpacing;
            const neuronSpacing = Math.min(30, (H - padding.y * 2) / (layer.neurons + 1));
            const startY = H / 2 - ((layer.neurons - 1) * neuronSpacing) / 2;
            return {
                ...layer,
                x,
                neuronPositions: Array.from({length: layer.neurons}, (_, ni) => ({
                    x, y: startY + ni * neuronSpacing
                }))
            };
        });

        // Draw connections — smooth bezier curves with layer-tinted color
        for (let i = 0; i < positions.length - 1; i++) {
            const from = positions[i];
            const to = positions[i + 1];
            const midX = (from.x + to.x) / 2;
            // Use the source layer color at a subtle but visible opacity
            const connAlpha = C('20', '22');  // hex alpha: ~12-13%
            ctx.strokeStyle = from.color + connAlpha;
            ctx.lineWidth = 0.8;
            from.neuronPositions.forEach(fp => {
                to.neuronPositions.forEach(tp => {
                    ctx.beginPath();
                    ctx.moveTo(fp.x, fp.y);
                    // Bezier curve with horizontal control points for smooth arcs
                    ctx.bezierCurveTo(midX, fp.y, midX, tp.y, tp.x, tp.y);
                    ctx.stroke();
                });
            });
        }

        // Draw neurons
        positions.forEach((layer, li) => {
            layer.neuronPositions.forEach((pos, ni) => {
                const r = layer.neurons === 1 ? 12 : 7;

                // Subtle halo
                ctx.fillStyle = layer.color + '18';
                ctx.beginPath();
                ctx.arc(pos.x, pos.y, r * 2.5, 0, Math.PI * 2);
                ctx.fill();

                // Neuron body
                ctx.fillStyle = layer.color;
                ctx.beginPath();
                ctx.arc(pos.x, pos.y, r, 0, Math.PI * 2);
                ctx.fill();

                // Border
                ctx.strokeStyle = layer.color + '60';
                ctx.lineWidth = 1;
                ctx.beginPath();
                ctx.arc(pos.x, pos.y, r, 0, Math.PI * 2);
                ctx.stroke();
            });

            // Labels
            ctx.fillStyle = c.labelStrong;
            ctx.font = 'bold 11px Inter';
            ctx.textAlign = 'center';
            ctx.fillText(layer.label, layer.x, H - 12);

            ctx.fillStyle = c.tick;
            ctx.font = '10px Inter';
            ctx.fillText(layer.sub, layer.x, H - 0);

            // "..." indicator for condensed layers
            if (layer.actual && layer.actual > layer.neurons) {
                const mid = layer.neuronPositions[Math.floor(layer.neurons / 2)];
                ctx.fillStyle = layer.color + '50';
                ctx.font = 'bold 16px Inter';
                ctx.fillText('...', layer.x + 20, mid.y);
            }
        });
    }

    // ═══════════════════════════════════════════════════
    // TRAINING TAB
    // ═══════════════════════════════════════════════════
    async function loadTraining() {
        try {
            const res = await fetch('/api/evaluation');
            const data = await res.json();
            const h = data.history;
            const t = data.training;
            const c = getChartColors();

            // Stats
            document.getElementById('ts-epochs').textContent = t.epochs_completed;
            document.getElementById('ts-best').textContent = t.best_epoch;
            document.getElementById('ts-val-auc').textContent = t.final_val_auc.toFixed(4);
            document.getElementById('ts-val-loss').textContent = t.final_val_loss.toFixed(4);
            document.getElementById('ts-lr').textContent = t.learning_rate_final;

            const chartOpts = {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: { legend: { position: 'top' } },
                scales: {
                    x: { title: { display: true, text: 'Epoch' }, grid: { color: c.grid } },
                    y: { grid: { color: c.grid } }
                }
            };

            // Loss Chart
            if (chartInstances['loss']) chartInstances['loss'].destroy();
            chartInstances['loss'] = new Chart(document.getElementById('chart-loss'), {
                type: 'line',
                data: {
                    labels: h.epochs,
                    datasets: [
                        { label: 'Train Loss', data: h.train_loss, borderColor: c.blue, backgroundColor: c.blue + '18', fill: true, tension: 0.3, pointRadius: 2, borderWidth: 2 },
                        { label: 'Val Loss',   data: h.val_loss,   borderColor: c.teal, backgroundColor: c.teal + '10', fill: true, tension: 0.3, pointRadius: 2, borderWidth: 2 },
                    ]
                },
                options: chartOpts
            });

            // AUC Chart
            if (chartInstances['auc']) chartInstances['auc'].destroy();
            chartInstances['auc'] = new Chart(document.getElementById('chart-auc'), {
                type: 'line',
                data: {
                    labels: h.epochs,
                    datasets: [
                        { label: 'Train AUC', data: h.train_auc, borderColor: c.green, backgroundColor: c.green + '18', fill: true, tension: 0.3, pointRadius: 2, borderWidth: 2 },
                        { label: 'Val AUC',   data: h.val_auc,   borderColor: c.amber, backgroundColor: c.amber + '10', fill: true, tension: 0.3, pointRadius: 2, borderWidth: 2 },
                    ]
                },
                options: { ...chartOpts, scales: { ...chartOpts.scales, y: { ...chartOpts.scales.y, min: 0.9 } } }
            });

            // Accuracy Chart
            if (chartInstances['acc']) chartInstances['acc'].destroy();
            chartInstances['acc'] = new Chart(document.getElementById('chart-acc'), {
                type: 'line',
                data: {
                    labels: h.epochs,
                    datasets: [
                        { label: 'Train Acc', data: h.train_acc, borderColor: c.mauve, backgroundColor: c.mauve + '18', fill: true, tension: 0.3, pointRadius: 2, borderWidth: 2 },
                        { label: 'Val Acc',   data: h.val_acc,   borderColor: c.terra, backgroundColor: c.terra + '10', fill: true, tension: 0.3, pointRadius: 2, borderWidth: 2 },
                    ]
                },
                options: { ...chartOpts, scales: { ...chartOpts.scales, y: { ...chartOpts.scales.y, min: 0.85 } } }
            });

            // Training Summary
            const summary = document.getElementById('training-summary');
            summary.innerHTML = `
                <div class="model-info-item"><div class="model-info-item__label">Early Stopped</div><div class="model-info-item__value">${t.early_stopped ? 'Yes' : 'No'}</div></div>
                <div class="model-info-item"><div class="model-info-item__label">Final Train Acc</div><div class="model-info-item__value">${(t.final_train_acc*100).toFixed(2)}%</div></div>
                <div class="model-info-item"><div class="model-info-item__label">Final Val Acc</div><div class="model-info-item__value">${(t.final_val_acc*100).toFixed(2)}%</div></div>
                <div class="model-info-item"><div class="model-info-item__label">Final Train AUC</div><div class="model-info-item__value">${t.final_train_auc.toFixed(4)}</div></div>
                <div class="model-info-item"><div class="model-info-item__label">Final Val AUC</div><div class="model-info-item__value">${t.final_val_auc.toFixed(4)}</div></div>
                <div class="model-info-item"><div class="model-info-item__label">Architecture</div><div class="model-info-item__value">[256, 128, 64]</div></div>
            `;

        } catch (err) {
            console.error(err);
        }
    }

    // ═══════════════════════════════════════════════════
    // EVALUATION TAB
    // ═══════════════════════════════════════════════════
    async function loadEvaluation() {
        try {
            const res = await fetch('/api/evaluation');
            const data = await res.json();
            const m = data.metrics;
            const cm = data.confusion_matrix;
            const ds = data.dataset;
            const c = getChartColors();

            // Stats
            document.getElementById('ev-roc').textContent = m.roc_auc.toFixed(4);
            document.getElementById('ev-pr').textContent = m.pr_auc.toFixed(4);
            document.getElementById('ev-recall').textContent = (m.recall_fraud * 100).toFixed(1) + '%';
            document.getElementById('ev-precision').textContent = (m.precision_fraud * 100).toFixed(1) + '%';
            document.getElementById('ev-f1').textContent = m.f1_fraud.toFixed(4);

            // Confusion Matrix
            document.getElementById('cm-tn').textContent = cm.tn.toLocaleString();
            document.getElementById('cm-fp').textContent = cm.fp.toLocaleString();
            document.getElementById('cm-fn').textContent = cm.fn.toLocaleString();
            document.getElementById('cm-tp').textContent = cm.tp.toLocaleString();

            // Metrics Bar Chart
            if (chartInstances['metrics']) chartInstances['metrics'].destroy();
            chartInstances['metrics'] = new Chart(document.getElementById('chart-metrics'), {
                type: 'bar',
                data: {
                    labels: ['Precision\n(Legit)', 'Recall\n(Legit)', 'F1\n(Legit)', 'Precision\n(Fraud)', 'Recall\n(Fraud)', 'F1\n(Fraud)'],
                    datasets: [{
                        data: [m.precision_legit, m.recall_legit, m.f1_legit, m.precision_fraud, m.recall_fraud, m.f1_fraud],
                        backgroundColor: [c.green+'40', c.green+'40', c.green+'40', c.blue+'40', c.blue+'40', c.blue+'40'],
                        borderColor:     [c.green,      c.green,      c.green,      c.blue,      c.blue,      c.blue],
                        borderWidth: 1.5,
                        borderRadius: 4,
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false } },
                        y: { min: 0, max: 1.1, grid: { color: c.grid } }
                    }
                }
            });

            // ROC Curve
            const rocPoints = [];
            for (let i = 0; i <= 100; i++) {
                const fpr = i / 100;
                const tpr = Math.pow(fpr, 0.012);
                rocPoints.push({ x: fpr, y: Math.min(tpr, 1) });
            }

            if (chartInstances['roc']) chartInstances['roc'].destroy();
            chartInstances['roc'] = new Chart(document.getElementById('chart-roc'), {
                type: 'scatter',
                data: {
                    datasets: [
                        {
                            label: 'ROC Curve',
                            data: rocPoints,
                            showLine: true,
                            borderColor: c.blue,
                            backgroundColor: c.blue + '18',
                            fill: true,
                            pointRadius: 0,
                            tension: 0.4,
                        },
                        {
                            label: 'Random',
                            data: [{x:0,y:0},{x:1,y:1}],
                            showLine: true,
                            borderColor: C('rgba(0,0,0,0.15)', 'rgba(255,255,255,0.15)'),
                            borderDash: [5,5],
                            pointRadius: 0,
                        }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'top' } },
                    scales: {
                        x: { title: { display: true, text: 'False Positive Rate' }, min: 0, max: 1, grid: { color: c.grid } },
                        y: { title: { display: true, text: 'True Positive Rate' },  min: 0, max: 1, grid: { color: c.grid } }
                    }
                }
            });

            // Dataset Info
            const dsDiv = document.getElementById('dataset-info');
            dsDiv.innerHTML = `
                <div class="model-info-item"><div class="model-info-item__label">Training Samples</div><div class="model-info-item__value">${ds.total_train.toLocaleString()}</div></div>
                <div class="model-info-item"><div class="model-info-item__label">Test Samples</div><div class="model-info-item__value">${ds.total_test.toLocaleString()}</div></div>
                <div class="model-info-item"><div class="model-info-item__label">Train Fraud Rate</div><div class="model-info-item__value">${ds.fraud_rate_train}%</div></div>
                <div class="model-info-item"><div class="model-info-item__label">Test Fraud Rate</div><div class="model-info-item__value">${ds.fraud_rate_test}%</div></div>
                <div class="model-info-item"><div class="model-info-item__label">Threshold</div><div class="model-info-item__value">0.5</div></div>
                <div class="model-info-item"><div class="model-info-item__label">Accuracy</div><div class="model-info-item__value">${(m.accuracy*100).toFixed(2)}%</div></div>
            `;

        } catch (err) {
            console.error(err);
        }
    }

    // ═══════════════════════════════════════════════════
    // TUNING TAB
    // ═══════════════════════════════════════════════════
    async function loadTuning() {
        try {
            const res = await fetch('/api/tuning');
            const data = await res.json();
            const trials = data.trials;
            const c = getChartColors();

            // Stats
            document.getElementById('tu-trials').textContent = data.total;
            if (trials.length > 0) {
                document.getElementById('tu-best-score').textContent = trials[0].score.toFixed(4);
                document.getElementById('tu-best-roc').textContent = trials[0].roc_auc.toFixed(4);
                document.getElementById('tu-best-pr').textContent = trials[0].pr_auc.toFixed(4);
            }

            // Chart
            const trialLabels = trials.map(t => 'Trial ' + t.trial);
            if (chartInstances['tuning']) chartInstances['tuning'].destroy();
            chartInstances['tuning'] = new Chart(document.getElementById('chart-tuning'), {
                type: 'bar',
                data: {
                    labels: trialLabels,
                    datasets: [
                        { label: 'ROC-AUC', data: trials.map(t => t.roc_auc), backgroundColor: c.blue + '70', borderColor: c.blue, borderWidth: 1, borderRadius: 4 },
                        { label: 'PR-AUC',  data: trials.map(t => t.pr_auc),  backgroundColor: c.green + '70', borderColor: c.green, borderWidth: 1, borderRadius: 4 },
                        { label: 'Score',    data: trials.map(t => t.score),   backgroundColor: c.amber + '70', borderColor: c.amber, borderWidth: 1, borderRadius: 4 },
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'top' } },
                    scales: {
                        x: { grid: { display: false } },
                        y: { min: 0.5, max: 1, grid: { color: c.grid } }
                    }
                }
            });

            // Table
            const tbody = document.getElementById('tuning-tbody');
            tbody.innerHTML = '';
            trials.forEach((t, i) => {
                const tr = document.createElement('tr');
                if (i === 0) tr.className = 'best';
                tr.innerHTML = `
                    <td>${t.trial}${i===0 ? '<span class="badge-best">BEST</span>' : ''}</td>
                    <td>${t.hidden_layers}</td>
                    <td>${t.dropout_rate}</td>
                    <td>${t.learning_rate}</td>
                    <td>${t.batch_size}</td>
                    <td>${t.epochs}</td>
                    <td>${t.roc_auc}</td>
                    <td>${t.pr_auc}</td>
                    <td>${t.score}</td>
                `;
                tbody.appendChild(tr);
            });

        } catch (err) {
            console.error(err);
        }
    }

