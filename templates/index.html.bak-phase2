        // ─── Chart 11: Stolen Funds by Category (Horizontal Bar) ───
        chartInstances['eda11'] = new Chart(document.getElementById('eda-chart-11'), {
            type: 'bar',
            data: {
                labels: ['shopping_pos','misc_net','grocery_pos','shopping_net','travel','misc_pos','entertainment','home','personal_care','kids_pets','food_dining','health_fitness','gas_transport'],
                datasets: [{
                    label: 'Median Stolen Amount ($)',
                    data: [560, 490, 320, 310, 420, 280, 260, 245, 220, 200, 185, 175, 65],
                    backgroundColor: c.red + 'A0',
                    borderColor: c.red, borderWidth: 1, borderRadius: 4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                indexAxis: 'y',
                plugins: {
                    legend: { display: false },
                    subtitle: { display: true, text: 'Outliers excluded. Shows median stolen amount.', color: c.tick, font: { size: 10, style: 'italic' }, padding: { bottom: 10 } }
                },
                scales: {
                    x: { title: { display: true, text: 'Transaction Amount ($)', color: c.tick }, grid: { color: c.grid }, ticks: { color: c.tick } },
                    y: { grid: { display: false }, ticks: { color: c.tick, font: { family: "'JetBrains Mono', monospace", size: 10 } } }
                }
            }
        });

        // ─── Chart 12: Most Exploited Merchants (Horizontal Bar) ───
        chartInstances['eda12'] = new Chart(document.getElementById('eda-chart-12'), {
            type: 'bar',
            data: {
                labels: [
                    'fraud_Kirlin and Sons', 'fraud_Spinka LLC', 'fraud_Strosin Inc',
                    'fraud_Leuschke Group', 'fraud_Gerhold LLC', 'fraud_Bechtelar LLC',
                    'fraud_Hegmann LLC', 'fraud_Hudson LLC', 'fraud_Rempel Inc', 'fraud_Mante LLC'
                ],
                datasets: [{
                    data: [42, 39, 37, 35, 33, 31, 30, 29, 28, 27],
                    backgroundColor: c.red + '90',
                    borderColor: c.red,
                    borderWidth: 1,
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                indexAxis: 'y',
                plugins: { legend: { display: false } },
                scales: {
                    x: { title: { display: true, text: 'Number of Fraudulent Transactions', color: c.tick }, grid: { color: c.grid }, ticks: { color: c.tick } },
                    y: { grid: { display: false }, ticks: { color: c.tick, font: { family: "'JetBrains Mono', monospace", size: 10 } } }
                }
            }
        });

        // ─── Chart 13: Correlation Heatmap (HTML/CSS Grid) ───
        buildCorrelationHeatmap();
    }

    function buildCorrelationHeatmap() {
        const c = getChartColors();
        const features = ['amt','hour','age','lat','merch_lat','distance_km','long','merch_long','cc_num','zip','city_pop','unix_time','is_fraud'];
        // Symmetric correlation matrix
        const matrix = {
            'amt':         { 'amt':1.00,'hour':-0.01,'age':0.002,'lat':0.005,'merch_lat':0.005,'distance_km':0.003,'long':0.002,'merch_long':0.002,'cc_num':-0.001,'zip':0.001,'city_pop':0.003,'unix_time':0.005,'is_fraud':0.18 },
            'hour':        { 'amt':-0.01,'hour':1.00,'age':0.001,'lat':0.002,'merch_lat':0.002,'distance_km':0.001,'long':0.001,'merch_long':0.001,'cc_num':0.001,'zip':0.001,'city_pop':0.002,'unix_time':0.01,'is_fraud':0.01 },
            'age':         { 'amt':0.002,'hour':0.001,'age':1.00,'lat':-0.01,'merch_lat':-0.01,'distance_km':0.003,'long':0.002,'merch_long':0.002,'cc_num':0.005,'zip':-0.003,'city_pop':-0.01,'unix_time':-0.002,'is_fraud':0.007 },
            'lat':         { 'amt':0.005,'hour':0.002,'age':-0.01,'lat':1.00,'merch_lat':0.65,'distance_km':0.05,'long':-0.40,'merch_long':-0.38,'cc_num':0.001,'zip':0.30,'city_pop':-0.10,'unix_time':0.001,'is_fraud':0.006 },
            'merch_lat':   { 'amt':0.005,'hour':0.002,'age':-0.01,'lat':0.65,'merch_lat':1.00,'distance_km':0.08,'long':-0.38,'merch_long':-0.37,'cc_num':0.001,'zip':0.28,'city_pop':-0.09,'unix_time':0.001,'is_fraud':0.006 },
            'distance_km': { 'amt':0.003,'hour':0.001,'age':0.003,'lat':0.05,'merch_lat':0.08,'distance_km':1.00,'long':-0.02,'merch_long':-0.02,'cc_num':0.001,'zip':0.02,'city_pop':-0.01,'unix_time':0.001,'is_fraud':0.0002 },
            'long':        { 'amt':0.002,'hour':0.001,'age':0.002,'lat':-0.40,'merch_lat':-0.38,'distance_km':-0.02,'long':1.00,'merch_long':0.60,'cc_num':0.001,'zip':-0.50,'city_pop':0.05,'unix_time':0.001,'is_fraud':-0.001 },
            'merch_long':  { 'amt':0.002,'hour':0.001,'age':0.002,'lat':-0.38,'merch_lat':-0.37,'distance_km':-0.02,'long':0.60,'merch_long':1.00,'cc_num':0.001,'zip':-0.48,'city_pop':0.05,'unix_time':0.001,'is_fraud':-0.001 },
            'cc_num':      { 'amt':-0.001,'hour':0.001,'age':0.005,'lat':0.001,'merch_lat':0.001,'distance_km':0.001,'long':0.001,'merch_long':0.001,'cc_num':1.00,'zip':0.001,'city_pop':0.001,'unix_time':0.001,'is_fraud':-0.002 },
            'zip':         { 'amt':0.001,'hour':0.001,'age':-0.003,'lat':0.30,'merch_lat':0.28,'distance_km':0.02,'long':-0.50,'merch_long':-0.48,'cc_num':0.001,'zip':1.00,'city_pop':-0.05,'unix_time':0.001,'is_fraud':-0.002 },
            'city_pop':    { 'amt':0.003,'hour':0.002,'age':-0.01,'lat':-0.10,'merch_lat':-0.09,'distance_km':-0.01,'long':0.05,'merch_long':0.05,'cc_num':0.001,'zip':-0.05,'city_pop':1.00,'unix_time':0.001,'is_fraud':-0.005 },
            'unix_time':   { 'amt':0.005,'hour':0.01,'age':-0.002,'lat':0.001,'merch_lat':0.001,'distance_km':0.001,'long':0.001,'merch_long':0.001,'cc_num':0.001,'zip':0.001,'city_pop':0.001,'unix_time':1.00,'is_fraud':-0.013 },
            'is_fraud':    { 'amt':0.18,'hour':0.01,'age':0.007,'lat':0.006,'merch_lat':0.006,'distance_km':0.0002,'long':-0.001,'merch_long':-0.001,'cc_num':-0.002,'zip':-0.002,'city_pop':-0.005,'unix_time':-0.013,'is_fraud':1.00 }
        };

        function corrColor(value) {
            const dark = isDark();
            if (value >= 0.99) return dark ? '#44403C' : '#E7E5E4';  // diagonal
            if (value > 0.5)  return dark ? '#8B4A3A' : '#C07A5C';
            if (value > 0.15) return dark ? '#A85C4C' : '#D49A7C';
            if (value > 0.05) return dark ? '#6E4A40' : '#E8C8B0';
            if (value > 0.01) return dark ? '#4A3830' : '#F0DDD0';
            if (value > -0.01) return dark ? '#292524' : '#F5F2EE';
            if (value > -0.05) return dark ? '#2E3A4A' : '#D0DEE8';
            if (value > -0.15) return dark ? '#3A5068' : '#BDD0E7';
            if (value > -0.5)  return dark ? '#3D6390' : '#7B9BC4';
            return dark ? '#2A4A6E' : '#5B7BA4';
        }

        function textColor(value) {
            const dark = isDark();
            const absV = Math.abs(value);
            if (value >= 0.99) return dark ? '#FAF8F5' : '#1C1917';
            if (absV > 0.3) return '#FAF8F5';
            if (absV > 0.1) return dark ? '#FAF8F5' : '#1C1917';
            return dark ? '#A8A29E' : '#78716C';
        }

        const container = document.getElementById('eda-heatmap');
        let html = '<div style="overflow-x:auto;"><table class="eda-corr-table"><thead><tr><th></th>';
        features.forEach(f => { html += '<th>' + f + '</th>'; });
        html += '</tr></thead><tbody>';

        features.forEach(row => {
            html += '<tr><td class="eda-corr-rowlabel">' + row + '</td>';
            features.forEach(col => {
                const val = matrix[row][col];
                const bg = corrColor(val);
                const fg = textColor(val);
                const bold = (Math.abs(val) > 0.15 && val < 0.99) ? 'font-weight:bold;' : '';
                const displayVal = val >= 0.99 ? '1.00' : val.toFixed(val === 0 ? 1 : (Math.abs(val) < 0.01 ? 4 : 2));
                html += '<td style="background:' + bg + ';color:' + fg + ';' + bold + '">' + displayVal + '</td>';
            });
            html += '</tr>';
        });

        html += '</tbody></table></div>';

        // Color scale legend
        html += '<div class="eda-corr-legend">';
        html += '<span class="eda-corr-legend__label">−1.0</span>';
        html += '<div class="eda-corr-legend__bar"></div>';
        html += '<span class="eda-corr-legend__label">0.0</span>';
        html += '<div class="eda-corr-legend__bar eda-corr-legend__bar--pos"></div>';
        html += '<span class="eda-corr-legend__label">+1.0</span>';
        html += '</div>';

        container.innerHTML = html;
    }

})();
</script>

</body>
</html>
